{
  "version": 2,
  "builds": [
    { "src": "*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/fahad", "dest": "/fahad.js" },
    { "src": "/jawad", "dest": "/jawad.js" },
    { "src": "/tufaill", "dest": "/tufaill.js" },
    { "src": "/mustjab", "dest": "/mustjab.js" },
    { "src": "/waqar", "dest": "/waqar.js" },
    { "src": "/GF", "dest": "/GF.js" },
    { "src": "/Destiny", "dest": "/Destiny.js" },
    { "src": "/faisal", "dest": "/faisal.js" }
  ]
}
